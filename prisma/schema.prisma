// cspell:ignore RoomMember RoomInvite gen_random_uuid emoji membe Membe MEMBE emoj

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

//// ─────────────────────────────
//// Core Models
//// ─────────────────────────────

/// プロフィール（auth.users と 1:1 / PK = user_id）
model Profile {
  /// auth.users.id を格納（UUID）。DB外部キーは張らない（アプリで整合性担保）
  userId    String   @id @map("user_id") @db.Uuid
  email     String?  @unique
  nickname  String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // relations
  memberships RoomMember[]
  messages    Message[]    @relation("ProfileMessages")
  reactions   Reaction[]   @relation("ProfileReactions")
  invitesSent RoomInvite[] @relation("ProfileInvites")
  roomsOwned  Room[]       @relation("ProfileOwnerRooms")

  @@map("profiles")
}

/// ルーム
model Room {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isPrivate Boolean  @default(false) @map("is_private")
  ownerId   String   @map("owner_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Profile との 1:N（オーナー）
  owner    Profile      @relation("ProfileOwnerRooms", fields: [ownerId], references: [userId])
  members  RoomMember[]
  messages Message[]
  invites  RoomInvite[]

  @@index([ownerId])
  @@map("rooms")
}

/// メンバーシップ（複合PK）
model RoomMember {
  roomId   String   @map("room_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     RoomRole @default(MEMBER)
  joinedAt DateTime @default(now()) @map("joined_at")

  room Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([roomId, userId])
  @@index([userId])
  @@index([roomId])
  @@map("room_members")
}

enum RoomRole {
  OWNER
  ADMIN
  MEMBER
}

/// メッセージ
model Message {
  id        String    @id @default(uuid()) @db.Uuid
  roomId    String    @map("room_id") @db.Uuid
  // 履歴保持のため nullable（退会ユーザーの投稿を残す）
  userId    String?   @map("user_id") @db.Uuid
  body      String
  createdAt DateTime  @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")

  room   Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  // userId が optional なので、relation 側も optional（?）にする
  author Profile? @relation("ProfileMessages", fields: [userId], references: [userId], onDelete: SetNull)

  attachments Attachment[]
  reactions   Reaction[]

  @@index([roomId, createdAt]) // 部屋内の時系列取得
  @@index([userId, createdAt]) // ユーザー別の時系列取得（退会処理などのバッチにも有効）
  @@map("messages")
}

/// 添付ファイル
model Attachment {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  url       String
  mimeType  String   @map("mime_type")
  size      Int?
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("attachments")
}

/// リアクション（複合PK）
model Reaction {
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    Profile @relation("ProfileReactions", fields: [userId], references: [userId], onDelete: Cascade)

  @@id([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

/// 招待（トークンユニーク）
model RoomInvite {
  id           String    @id @default(uuid()) @db.Uuid
  roomId       String    @map("room_id") @db.Uuid
  inviterId    String    @map("inviter_id") @db.Uuid
  inviteeEmail String    @map("invitee_email")
  token        String    @unique
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  acceptedAt   DateTime? @map("accepted_at")

  room    Room    @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter Profile @relation("ProfileInvites", fields: [inviterId], references: [userId])

  @@index([roomId])
  @@map("room_invites")
}
